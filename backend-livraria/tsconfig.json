{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "lib": ["es2020"],
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,

    "rootDir": "src",
    "outDir": "dist",

    "baseUrl": ".",
    "paths": {
      "*": ["node_modules/*"]
    },

  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "prisma"]
}
